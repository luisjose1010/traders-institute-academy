# =============================================
# Traders Institute Academy — Development .env
# Copy to .env and fill in your values
# =============================================

# --- Turso (LibSQL) Database ---
TURSO_DATABASE_URL=libsql://your-database-here.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# --- Auth ---
JWT_SECRET=change-me-to-a-random-string

# --- Email (Resend) ---
# Free tier: only delivers to verified domain or account email
RESEND_API_KEY=re_your_resend_api_key

# --- Frontend ---
# URL of the frontend (for CORS + email links)
FRONTEND_URL=http://localhost:5173

# --- Vite (Frontend) ---
# API base URL for the frontend build
VITE_API_URL=http://localhost:3000

# --- Optional ---
# Comma-separated CORS origins (defaults to localhost:5173, localhost:3000)
# CORS_ORIGIN=https://yourdomain.com
# Backend port (default 3000)
# PORT=3000
